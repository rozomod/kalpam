{
  "name": "@kalpam/oxlint-config",
  "version": "0.0.0",
  "description": "Shared oxlint config for kalpam projects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rozomod/kalpam.git",
    "directory": "packages/oxlint-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@kalpam/tsconfig": "workspace:*",
    "oxlint": "^1.67.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "oxlint": ">=1.63.0"
  }
}
